rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow Admin SDK operations (bypass security rules)
    match /{document=**} {
      allow read, write: if request.auth == null;
    }
    
    // Only allow authenticated users to access their own sessions
    // Only allow authenticated users to access their own sessions
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Allow users to create new sessions with their userId
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Subcollections for messages and artifacts
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      }
      
      match /artifacts/{artifactId} {
        allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      }
    }

    // Token quotas - server-only access via Admin SDK
    match /token_quotas/{userId} {
      allow read, write: if false; // server-only via admin SDK
    }
  }
}
